# ---- Telegram (required) ----
# Create a bot with @BotFather to get the token, then get your chat id from
# @userinfobot (or https://api.telegram.org/bot<token>/getUpdates after messaging the bot).
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# ---- Watchlist (seeded on first run; afterwards manage live from Telegram) ----
WATCHLIST=BTC/USDT,SOL/USDT,ETH/USDT,DOGE/USDT
TIMEFRAME=4h
POLL_SECONDS=300          # how often to poll for a new closed candle (seconds)
ANALYZE_SINCE=2020-01-01  # how far back /analyze and /backtest fetch history
REANALYZE_DAYS=30         # auto re-tune each coin when its params age past this (0=off)
MIN_OOS_SHARPE=0.0        # /analyze auto-disables a coin if OOS Sharpe < this
WEAK_OOS_SHARPE=0.5       # OOS Sharpe in [MIN, WEAK) is kept but flagged "weak"

# ---- Weekly performance report (also on demand via /summary) ----
WEEKLY_REPORT=true
REPORT_DAY=0              # 0=Monday .. 6=Sunday
REPORT_HOUR=9            # UTC hour to send the weekly report

# ---- Strategy family ----
# trend = EMA/RSI/ATR signal system | hold = buy & hold with a bear filter
# (stay long above REGIME_EMA, go to cash below it — much lower drawdown).
STRATEGY=trend
REGIME_EMA=200

# ---- Default/seed strategy params (used for a new coin until you /analyze it) ----
EMA_FAST=50
EMA_SLOW=200
RSI_PERIOD=14
RSI_LONG_MIN=50
RSI_LONG_MAX=70
ATR_PERIOD=14
ATR_SL_MULT=2.0
ATR_TP_MULT=4.0

# ---- Cross-sectional momentum (long/short) basket ----
# Ranks a broad universe by momentum and posts an equal-weight long (and short)
# basket each rebalance. The strongest research edge: ~market- & funding-neutral
# when run long/short. Independent of the per-coin watchlist above. On demand via
# /xsmom; auto-rebalances every XSMOM_REBALANCE_DAYS when XSMOM_ENABLED=true.
XSMOM_ENABLED=false
XSMOM_UNIVERSE=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT,BNB/USDT,ADA/USDT,DOGE/USDT,AVAX/USDT,LINK/USDT,DOT/USDT,TRX/USDT,MATIC/USDT,LTC/USDT,BCH/USDT,ATOM/USDT,UNI/USDT,NEAR/USDT,APT/USDT,INJ/USDT,SUI/USDT,TON/USDT,FIL/USDT,ARB/USDT,OP/USDT,AAVE/USDT
XSMOM_TIMEFRAME=1d        # daily momentum is the most robust (1d recommended)
XSMOM_LOOKBACK=30         # momentum lookback in bars (30 daily bars ~ 1 month)
XSMOM_TOP_K=5             # hold the strongest K long (and weakest K short)
XSMOM_REBALANCE_DAYS=7    # how often to recompute & re-post the basket
XSMOM_LONG_SHORT=true     # true = market-neutral long/short; false = long-only

# ---- Futures settings ----
ALLOW_SHORT=false         # futures: true lets /analyze also use SHORT entries
LEVERAGE=1.0              # futures leverage (1 = none). HIGH leverage = liquidation risk!
TAKER_FEE=0.0004          # per-side taker fee (Binance USDT-M futures ~0.04%; spot 0.10%)
MAINT_MARGIN=0.005        # maintenance-margin rate used for the liquidation price
FUNDING_8H=0.0001         # avg perpetual funding per 8h (~0.01%); longs pay / shorts receive

# Each watched coin keeps its own parameters, open position and trade history.
# Manage everything from Telegram: /list /add /remove /enable /disable /analyze
# and query per coin: /status /position /stats /history /price /params.
