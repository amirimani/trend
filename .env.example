# ---- Telegram (required) ----
# Create a bot with @BotFather to get the token, then get your chat id from
# @userinfobot (or https://api.telegram.org/bot<token>/getUpdates after messaging the bot).
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# ---- Market ----
SYMBOL=BTC/USDT
TIMEFRAME=4h
POLL_SECONDS=300          # how often to poll for a new closed candle (seconds)

# ---- Strategy params (must match what you backtested) ----
EMA_FAST=50
EMA_SLOW=200
RSI_PERIOD=14
RSI_LONG_MIN=50
RSI_LONG_MAX=70
ATR_PERIOD=14
ATR_SL_MULT=2.0
ATR_TP_MULT=4.0
ALLOW_SHORT=false         # set true to also alert SHORT entries

# The bot tracks each alerted position and sends a follow-up result message
# (profit/loss % and R multiple) when its TP, SL, or a trend-flip exit is hit.
